cloudflare_zone_id          = "set-as-github-variable"
minecraft_domain            = "mc.example.com"
azure_resource_group_name   = "replace-me-mc-rg"
resource_name_prefix        = "replace-me-mc"
image_repository            = "ghcr.io/owner/repo"
image_tag                   = "commit-sha"
velocity_forwarding_secret  = "set-as-github-secret"

# Required only if the container images are private.
container_registry_username = "github-username"
container_registry_password = "github-pat-with-package-read"
